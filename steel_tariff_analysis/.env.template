# API Keys for data collection
# Copy this file to .env and fill in your actual API keys

# Census Bureau API Key
# Get your key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# FRED API Key
# Get your key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# BLS API Key (optional, but recommended for higher rate limits)
# Get your key at: https://www.bls.gov/developers/home.htm
BLS_API_KEY=your_bls_api_key_here
